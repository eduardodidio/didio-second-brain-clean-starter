{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(bash patterns/hooks/*)",
      "Bash(bun install)",
      "Bash(bun:*)",
      "Bash(cd mcp-server && bun:*)",
      "Bash(didio-dashboard*)",
      "Bash(didio-run-wave*)",
      "Bash(didio-spawn-agent*)",
      "Bash(didio:*)",
      "Bash(diff:*)",
      "Bash(git add:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git status:*)",
      "Bash(shasum:*)",
      "Edit(./**)",
      "Read(./**)",
      "Write(docs/**)",
      "Write(knowledge/**)",
      "Write(logs/**)",
      "Write(mcp-server/**)",
      "Write(patterns/**)",
      "Write(tasks/**)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash patterns/hooks/stop-session-summary/hook.sh"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash patterns/hooks/subagent-stop-progress/hook.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash $(didio which hooks)/didio-pre-tool.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash patterns/hooks/post-tool-use-error/hook.sh"
          }
        ]
      },
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash $(didio which hooks)/didio-post-tool.sh"
          }
        ]
      }
    ]
  }
}
