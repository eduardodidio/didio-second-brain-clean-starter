# Discord observability webhooks (see docs/prd/F03-discord-notifications.md).
# Create 3 channels in your server, copy each webhook URL here.
# Keep DISCORD_ENABLED=false in CI to avoid spamming channels.
DISCORD_WEBHOOK_PROGRESS=https://discord.com/api/webhooks/REPLACE_ME/REPLACE_ME
DISCORD_WEBHOOK_ALERTS=https://discord.com/api/webhooks/REPLACE_ME/REPLACE_ME
DISCORD_WEBHOOK_DONE=https://discord.com/api/webhooks/REPLACE_ME/REPLACE_ME
DISCORD_ENABLED=true
